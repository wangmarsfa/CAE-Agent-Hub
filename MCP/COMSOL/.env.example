# Optional explicit COMSOL installation root.
# Example: C:\Program Files\COMSOL\COMSOL62\Multiphysics
COMSOL_ROOT=

# Optional executable overrides.
COMSOL_EXE=
COMSOLBATCH_EXE=
COMSOL_MPHSERVER_EXE=
JAVA_EXE=

# Directory where MCP-generated models, exports, and job metadata are written.
COMSOL_MCP_RUNS_DIR=

# Optional bridge command. If unset, the server tries COMSOL_MCP_BRIDGE_JAR.
# Example:
# COMSOL_MCP_BRIDGE_COMMAND=java -jar E:\Code\CAE-Agent-Hub\MCP\COMSOL\bridge\target\comsol-bridge.jar
COMSOL_MCP_BRIDGE_COMMAND=
COMSOL_MCP_BRIDGE_JAR=

# Bridge request timeout in seconds.
COMSOL_MCP_BRIDGE_TIMEOUT=120
