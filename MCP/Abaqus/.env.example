# Local socket endpoint used by the external MCP server and Abaqus/CAE bridge.
ABAQUS_MCP_HOST=127.0.0.1
ABAQUS_MCP_PORT=48152
ABAQUS_MCP_TIMEOUT=60

# Folder containing abaqus_mcp_plugin.py. Needed by the optional Abaqus GUI
# plugin loader when this project is not installed at %USERPROFILE%\.abaqus-mcp.
ABAQUS_MCP_HOME=C:\path\to\text-to-cae\MCP\Abaqus

# Optional bridge log path. Defaults to the system temp directory.
ABAQUS_MCP_LOG=
