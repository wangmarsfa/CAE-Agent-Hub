# Abaqus Environment Configuration
# Auto-load the Abaqus MCP socket bridge menu on CAE startup.
#
# Installation:
#   Copy this file to your Abaqus startup environment file.
#   Windows: C:\Users\YourUsername\abaqus_v6.env
#   Linux/Mac: ~/abaqus_v6.env

import os


def onCaeStartup():
    """Called when Abaqus/CAE starts."""
    mcp_home = os.environ.get("ABAQUS_MCP_HOME", "").strip()
    if not mcp_home:
        mcp_home = os.path.expanduser("~/.abaqus-mcp")
    mcp_plugin = os.path.join(mcp_home, "abaqus_mcp_plugin.py")

    if os.path.exists(mcp_plugin):
        import __main__
        if not getattr(__main__, "_ABAQUS_MCP_MENU_REGISTERED", False):
            with open(mcp_plugin, "r") as handle:
                exec(compile(handle.read(), mcp_plugin, "exec"), __main__.__dict__)
    else:
        print("Abaqus MCP plugin not found: " + mcp_plugin)
